<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Weight_Range</fullName>
    <active>true</active>
    <errorConditionFormula>Weight__c &lt; 0 || Weight__c &gt; 100</errorConditionFormula>
    <errorDisplayField>Weight__c</errorDisplayField>
    <errorMessage>The weight must be between 0 and 100</errorMessage>
</ValidationRule>
